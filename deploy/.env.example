# Copy to deploy/.env (git-ignored) and set real values. Never commit deploy/.env.
#
# ADR-0032 — secrets are file-backed. The credential values below are NOT read directly by the containers; they
# feed deploy/scripts/gen-secrets.sh, which writes deploy/secrets/* (git-ignored, mode 600). Those files are what
# docker compose mounts as Docker secrets. Non-secret values (hostnames, URLs, ports, cron) are still interpolated
# from this file at compose time. Bring the stack up with `deploy/scripts/up.sh` (runs gen-secrets, then compose).
# The values here are DEV/CI placeholders — the prod overlay + a real deploy/.env carry the actual secrets.
MSSQL_SA_PASSWORD=ChangeMe_Strong#2026
MINIO_ROOT_USER=acmpminio
MINIO_ROOT_PASSWORD=ChangeMe_Minio#2026

# Self-hosted Keycloak (ADR-0015): bundled IdP + ACMP-owned realm; zero external runtime services.
# Bootstrap admin for the Keycloak admin console (create/manage ACMP-realm users by hand — Q3).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_KC#2026
# Keycloak's own Postgres store (OQ-038 option a). App data stays SQL-Server-only (ADR-0003).
KC_DB_USER=keycloak
KC_DB_PASSWORD=ChangeMe_KCDB#2026
# Keycloak public base URL (KC_HOSTNAME) — the frontend/issuer host. Default = the in-stack localhost realm.
# ngrok-only (PR-C): set to https://acmp.ngrok.dev/kc — the web nginx proxies /kc/ to Keycloak so the IdP is
# same-origin with the SPA over https (no mixed content). Keep the three KEYCLOAK_* values consistent.
KEYCLOAK_HOSTNAME=http://keycloak.localhost:8085
# Issuer URL the API validates against — must match the SPA's VITE_OIDC_AUTHORITY byte-for-byte
# (= KEYCLOAK_HOSTNAME + /realms/acmp). ngrok-only: https://acmp.ngrok.dev/kc/realms/acmp.
KEYCLOAK_AUTHORITY=http://keycloak.localhost:8085/realms/acmp
# Keycloak ORIGIN (scheme+host[+port]) for the SPA's CSP connect-src/frame-src (nginx template).
# ngrok-only: https://acmp.ngrok.dev (same origin as the SPA).
KEYCLOAK_ORIGIN=http://keycloak.localhost:8085

# --- Webex integration (P13, Phase 2, ADR-0005/0023/0024) ---------------------------------------------------
# Default OFF: leave WEBEX_ENABLED=false and the adapter is not wired at all — in-app is the sole channel
# (AC-071). To enable, set true and fill every value below; the API and worker containers read the SAME set.
# All of these are SECRETS or environment-specific — never commit real values.
WEBEX_ENABLED=false
WEBEX_BOT_TOKEN=CHANGE_ME
WEBEX_SPACE_ID=CHANGE_ME
WEBEX_WEBHOOK_SECRET=CHANGE_ME
# Public URL Webex calls for the recording-ready webhook (the ngrok tunnel URL, or your reverse-proxy URL).
WEBEX_WEBHOOK_PUBLIC_URL=
# Base URL of this ACMP instance, used for the deep-link buttons in the Adaptive Cards.
WEBEX_ACMP_BASE_URL=http://localhost:8088
# Secretary OAuth app (meeting auto-create — a bot can't host). Redirect URI must be registered in Webex.
WEBEX_OAUTH_CLIENT_ID=CHANGE_ME
WEBEX_OAUTH_CLIENT_SECRET=CHANGE_ME
WEBEX_OAUTH_REDIRECT_URI=http://localhost:8080/api/webex/oauth/callback
# Key used to AES-GCM-encrypt the stored OAuth tokens at rest (any long random string).
WEBEX_TOKEN_ENCRYPTION_KEY=CHANGE_ME
# Operator-only gate for OAuth consent: /api/webex/oauth/start?key=<this> (fail-closed; without it /start is
# 404, so the consent flow can't be initiated by an unauthenticated caller). Any long random string.
WEBEX_OAUTH_SETUP_KEY=CHANGE_ME

# ngrok ingress for the webhook (opt-in: `docker compose --profile ngrok up`). Authtoken from your ngrok
# account (SECRET). NGROK_URL = your reserved ngrok domain, required when the profile is active:
#   dev  -> https://acmp.ngrok.dev
#   prod -> https://acmp.ngrok.app
# The tunnel points at web:80 (nginx), which serves the SPA and proxies /api to the API.
NGROK_AUTHTOKEN=
NGROK_URL=https://acmp.ngrok.dev
