# Copy to deploy/.env (git-ignored) and set real values. Never commit deploy/.env.
MSSQL_SA_PASSWORD=ChangeMe_Strong#2026
MINIO_ROOT_USER=acmpminio
MINIO_ROOT_PASSWORD=ChangeMe_Minio#2026

# Self-hosted Keycloak (ADR-0015): bundled IdP + ACMP-owned realm; zero external runtime services.
# Bootstrap admin for the Keycloak admin console (create/manage ACMP-realm users by hand — Q3).
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_KC#2026
# Keycloak's own Postgres store (OQ-038 option a). App data stays SQL-Server-only (ADR-0003).
KC_DB_USER=keycloak
KC_DB_PASSWORD=ChangeMe_KCDB#2026
# Issuer URL the API validates against — must match the SPA's VITE_OIDC_AUTHORITY byte-for-byte.
# Default (in deploy/docker-compose.yml) is the in-stack realm; override only for a custom hostname.
KEYCLOAK_AUTHORITY=http://keycloak.localhost:8085/realms/acmp
# Keycloak ORIGIN (scheme+host+port) for the SPA's CSP connect-src/frame-src (nginx template).
KEYCLOAK_ORIGIN=http://keycloak.localhost:8085
