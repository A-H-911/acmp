# Copy to deploy/.env (git-ignored) and set real values. Never commit deploy/.env.
MSSQL_SA_PASSWORD=ChangeMe_Strong#2026
MINIO_ROOT_USER=acmpminio
MINIO_ROOT_PASSWORD=ChangeMe_Minio#2026

# Keycloak OIDC (ADR-0004). Override the appsettings placeholders via ASP.NET env-var syntax
# (double underscore = nested key). Leave Authority empty to stay fail-closed (every request 401).
# Add these to the api service's `environment:` in docker-compose to activate a realm.
#   Authentication__Keycloak__Authority=https://keycloak.example/realms/acmp
#   Authentication__Keycloak__Audience=acmp-api
# Assign a minimum role to tokens with no recognised ACMP role claim (default: deny / unset):
#   Authorization__RoleMapping__DefaultRole=Submitter
