# Multi-stage build for the React SPA served by nginx (docs/33).
FROM node:22-alpine AS build
WORKDIR /web
COPY src/Acmp.Web/package.json src/Acmp.Web/package-lock.json ./
RUN npm ci
COPY src/Acmp.Web/ ./
RUN npm run build

FROM nginx:alpine AS final
COPY deploy/nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /web/dist /usr/share/nginx/html
EXPOSE 80
