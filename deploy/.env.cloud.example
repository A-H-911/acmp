# ACMP CLOUD environment template (PH-5 / SL-021). Copy to deploy/.env ON THE INSTANCE and
# fill in. deploy/.env is git-ignored — never commit real values (INV-007).
#
#   cp deploy/.env.cloud.example deploy/.env && $EDITOR deploy/.env
#   sh deploy/scripts/gen-secrets.sh
#   docker compose -f deploy/docker-compose.cloud.yml --env-file deploy/.env up -d
#
# EVERY value below differs between UAT and production. Getting one wrong breaks login or
# leaks UAT traffic into the committee's real Webex space.

# --- environment identity ---------------------------------------------------------------
# UAT  -> uat.acmp.anas7ammo.dev      PROD -> acmp.anas7ammo.dev
ACMP_ENV=uat
ACMP_HOST=uat.acmp.anas7ammo.dev

# --- images (ECR, pushed by CI in slice P24) ----------------------------------------------
# Never build on the box: npm ci + dotnet publish need ~2 GiB each and will OOM a 4 GiB host.
ACMP_REGISTRY=565393059398.dkr.ecr.us-east-1.amazonaws.com/acmp
ACMP_IMAGE_TAG=latest
AWS_REGION=us-east-1

# --- Keycloak (ADR-0036: persists to SQL Server; ADR-0037: same-origin under /kc) ----------
# All three MUST stay consistent; KEYCLOAK_AUTHORITY must equal the SPA's VITE_OIDC_AUTHORITY
# byte-for-byte (it is baked into the web image at build time).
KEYCLOAK_HOSTNAME=https://uat.acmp.anas7ammo.dev/kc
KEYCLOAK_AUTHORITY=https://uat.acmp.anas7ammo.dev/kc/realms/acmp
KEYCLOAK_ORIGIN=https://uat.acmp.anas7ammo.dev
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME
# Keycloak's SQL Server login (sqlserver-init creates it; gen-secrets writes the secret).
ACMP_KC_DB_NAME=keycloak
ACMP_KC_DB_USER=keycloak_svc
ACMP_KC_DB_PASSWORD=CHANGE_ME

# --- SQL Server ---------------------------------------------------------------------------
MSSQL_SA_PASSWORD=CHANGE_ME
ACMP_DB_NAME=Acmp
# Least-priv runtime login (ADR-0031). Leave as acmp_svc — 'sa' would bypass the audit DENY.
ACMP_DB_USER=acmp_svc
ACMP_DB_PASSWORD=CHANGE_ME
ACMP_DB_TRUSTCERT=True
ACMP_BACKUP_DIR=/opt/acmp/backups

# --- S3 object storage (ADR-0035; keys emitted by deploy/aws/03-iam.sh) -------------------
ACMP_S3_ENDPOINT=s3.us-east-1.amazonaws.com
ACMP_S3_BUCKET=acmp-uat-recordings
ACMP_S3_ACCESS_KEY=CHANGE_ME
ACMP_S3_SECRET_KEY=CHANGE_ME

# --- observability ------------------------------------------------------------------------
# Seq runs in BOTH environments (CON-001 self-hosted observability). Generate the hash with:
#   docker run --rm datalust/seq config hash
SEQ_FIRSTRUN_ADMINPASSWORDHASH=CHANGE_ME

# --- ports / TLS ---------------------------------------------------------------------------
ACMP_HTTP_PORT=80
ACMP_HTTPS_PORT=443
ACMP_REQUIRE_HTTPS_METADATA=true

# --- Webex (OQ-062: OFF in UAT until a dedicated UAT space + bot exist) --------------------
# NEVER point UAT at the production Webex space.
WEBEX_ENABLED=false
#WEBEX_SPACE_ID=
#WEBEX_WEBHOOK_PUBLIC_URL=https://uat.acmp.anas7ammo.dev/api/webex/webhook
#WEBEX_ACMP_BASE_URL=https://uat.acmp.anas7ammo.dev
#WEBEX_OAUTH_CLIENT_ID=
#WEBEX_OAUTH_REDIRECT_URI=https://uat.acmp.anas7ammo.dev/api/webex/oauth/callback
#WEBEX_BOT_TOKEN=
#WEBEX_WEBHOOK_SECRET=
#WEBEX_OAUTH_CLIENT_SECRET=
#WEBEX_TOKEN_ENCRYPTION_KEY=
#WEBEX_OAUTH_SETUP_KEY=

# Hangfire action-reminder sweep (default daily 06:00). MUST be quoted: gen-secrets.sh
# SOURCES this file, so an unquoted cron expression is parsed as a command + arguments.
ACTION_REMINDERS_SWEEP_CRON="0 6 * * *"
