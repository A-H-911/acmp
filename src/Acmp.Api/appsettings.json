{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "Acmp.Api" }
  },
  "ConnectionStrings": {
    "Acmp": "Server=sqlserver;Database=Acmp;User Id=sa;Password=CHANGE_ME_IN_ENV;TrustServerCertificate=True;Encrypt=False"
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "CHANGE_ME_IN_ENV",
    "Secure": "false"
  },
  "AllowedHosts": "*"
}
