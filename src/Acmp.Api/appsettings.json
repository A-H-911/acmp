{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "Acmp.Api" }
  },
  "ConnectionStrings": {
    "Acmp": "Server=sqlserver;Database=Acmp;User Id=sa;Password=CHANGE_ME_IN_ENV;TrustServerCertificate=True;Encrypt=False"
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "CHANGE_ME_IN_ENV",
    "Secure": "false"
  },
  "Authentication": {
    "Keycloak": {
      "//": "Keycloak OIDC realm (ADR-0004). Empty Authority => every token is rejected and protected endpoints return 401 (fail-closed). Set per environment via env vars.",
      "Authority": "",
      "Audience": "acmp-api",
      "RequireHttpsMetadata": true
    }
  },
  "Authorization": {
    "RoleMapping": {
      "//": "Keycloak claim -> canonical ACMP role. Standard shapes are handled automatically; ClaimToRole adds overrides. DefaultRole=null => deny when a validated token carries no recognised role (AC-003).",
      "ClaimToRole": {},
      "DefaultRole": null
    }
  },
  "AllowedHosts": "*"
}
