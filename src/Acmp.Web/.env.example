# ACMP web — Vite env vars. Copy to `.env.local` (git-ignored) to configure.
# Only VITE_*-prefixed vars reach the browser bundle; never put secrets here.
#
# When VITE_OIDC_AUTHORITY + VITE_OIDC_CLIENT_ID are set, the SPA authenticates
# against Keycloak (auth-code + PKCE). When they are unset in `npm run dev`, a
# DEV-only auth stub runs so the shell is usable without a live IdP. A
# production build with no OIDC config fails closed (no stub). Full Keycloak
# login + server claim→role mapping land in P4.

# Keycloak realm OIDC issuer URL, e.g. https://keycloak.example.org/realms/acmp
VITE_OIDC_AUTHORITY=

# Public SPA client id registered in the realm (no client secret for a public client)
VITE_OIDC_CLIENT_ID=acmp-web

# Requested scopes (space-separated). Roles arrive via realm/client role claims.
VITE_OIDC_SCOPE=openid profile email
