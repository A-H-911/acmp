{
  "name": "acmp-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:up": "docker compose -f ../../deploy/docker-compose.yml --env-file ../../deploy/.env.example up -d --build --wait",
    "e2e:down": "docker compose -f ../../deploy/docker-compose.yml --env-file ../../deploy/.env.example down -v"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-sans-arabic": "^5.2.9",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@tanstack/react-query": "^5.101.1",
    "dompurify": "^3.4.12",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "marked": "^18.0.6",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-oidc-context": "^3.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.6",
    "axe-core": "^4.10.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}
