{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "Acmp.Worker" }
  },
  "ConnectionStrings": {
    "Acmp": "Server=sqlserver;Database=Acmp;User Id=sa;Password=CHANGE_ME_IN_ENV;TrustServerCertificate=True;Encrypt=True"
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "CHANGE_ME_IN_ENV",
    "Secure": "false"
  },
  "Webex": {
    "//": "Must match the API's Webex config (same job graph, ADR-0024). Enabled=false => no Webex jobs run here. All secrets via env vars, never committed.",
    "Enabled": false,
    "BotToken": "CHANGE_ME_IN_ENV",
    "SpaceId": "CHANGE_ME_IN_ENV",
    "ApiBaseUrl": "https://webexapis.com/v1",
    "WebhookSecret": "CHANGE_ME_IN_ENV",
    "SignatureAlgorithm": "HMACSHA1",
    "WebhookPublicUrl": "",
    "AcmpBaseUrl": "",
    "DefaultLanguage": "en",
    "OAuthClientId": "CHANGE_ME_IN_ENV",
    "OAuthClientSecret": "CHANGE_ME_IN_ENV",
    "OAuthRedirectUri": "",
    "OAuthScopes": "spark:messages_write meeting:schedules_write meeting:recordings_read",
    "TokenEncryptionKey": "CHANGE_ME_IN_ENV"
  },
  "ActionReminders": {
    "//": "W22 reminder+escalation sweep — REGISTERED AND RUN by this worker (ADR-0024). SweepCron = Hangfire CRON (default daily 06:00).",
    "DueReminderDaysBefore": 3,
    "EscalateToSecretaryAfterDays": 7,
    "EscalateToChairmanAfterDays": 14,
    "OverdueMode": "DailyWhileOverdue",
    "SweepCron": "0 6 * * *"
  }
}
