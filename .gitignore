# ── .NET ──────────────────────────────────────────────
bin/
obj/
out/
artifacts/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
*.userosscache
.vs/
TestResults/
*.trx
*.coverage
*.cobertura.xml
coverage.*.json
project.lock.json
.dotnet/

# ── Node / Vite ───────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
coverage/
playwright-report/
test-results/
*.local

# ── Env & secrets (NEVER commit) ──────────────────────
*.env
!*.env.example
deploy/secrets/*
!deploy/secrets/.gitkeep
deploy/nginx/certs/*
!deploy/nginx/certs/.gitkeep

# ── OS / editor ───────────────────────────────────────
.DS_Store
Thumbs.db
*.swp

# ── Logs ──────────────────────────────────────────────
*.log

# Playwright MCP scratch artifacts (screenshots, snapshots)
.playwright-mcp/

# ── Tamheed package (planning store) ──────────────────
# Single-writer lockfile — transient, never committed
tamheed-package/data/.lock
# handoff_emit's executor MCP config: machine-specific absolute path into the
# local plugin cache; the tamheed plugin already registers the server locally
/.mcp.json
