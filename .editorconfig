root = true

[*]
charset = utf-8
indent_style = space
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_size = 4
charset = utf-8-bom
# Sensible C# analyzer defaults; dotnet format enforces the rest.
dotnet_sort_system_directives_first = true
csharp_style_namespace_declarations = file_scoped:warning

[*.{js,jsx,ts,tsx,json,jsonc,css,scss,html,yml,yaml}]
indent_size = 2

[*.{csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
