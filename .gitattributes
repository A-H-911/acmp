# Normalize line endings; LF everywhere except where a tool needs CRLF.
* text=auto eol=lf

*.cs      text eol=lf
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.sln     text eol=crlf
*.sh      text eol=lf
*.ps1     text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
